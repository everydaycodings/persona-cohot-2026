# --- LLM (OpenRouter) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
# Any OpenRouter model id your account can access. Default is cheap, fast, and
# strong at Hinglish. Other good picks: anthropic/claude-3.7-sonnet,
# meta-llama/llama-3.3-70b-instruct, deepseek/deepseek-chat
# (Note: some Google/Anthropic slugs may be blocked by your OpenRouter data-policy
#  settings and return "No endpoints found" — pick one your key can reach.)
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Embeddings (for RAG) ---
# Uses the same OPENROUTER_API_KEY above (OpenRouter serves embeddings too),
# reduced to 768 dims to match the pgvector column. Just pick a model.
EMBEDDINGS_MODEL=openai/text-embedding-3-small

# --- Database (Postgres with pgvector: Neon / Supabase / local) ---
DATABASE_URL=postgresql://user:password@host:5432/persona?sslmode=require

# --- App config ---
# Max chat messages per anonymous visitor per day
DAILY_MESSAGE_LIMIT=40
# Public site origin, used for OpenRouter attribution headers (optional)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
